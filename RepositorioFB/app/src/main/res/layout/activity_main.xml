<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="50dp"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sección:"
        android:textSize="18sp"/>

    <Spinner
        android:id="@+id/spinseccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/seccion"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asignatura:"
        android:textSize="18sp"
        android:layout_marginTop="10dp"/>

    <Spinner
        android:id="@+id/spinarea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:entries="@array/asignaturas"/>

    <EditText
        android:id="@+id/editTextText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Escribe el tema"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/btnregistrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registrar Clase"
        android:layout_marginTop="15dp"/>

    <Button
        android:id="@+id/btnCursos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mostrar Cursos"
        android:layout_marginTop="10dp"/>

</LinearLayout>
